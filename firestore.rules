rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /vehicles/{vehicleId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /site/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
